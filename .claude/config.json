{
  "api_key": "YOUR_OPENROUTER_API_KEY",
  "base_url": "https://openrouter.ai/api/v1",

  "default_model": "qwen/qwen3-235b-a22b:free",

  "models": [
    {
      "name": "primary",
      "model": "qwen/qwen3-235b-a22b:free",
      "temperature": 0.2,
      "max_tokens": 4096
    },
    {
      "name": "fallback_1",
      "model": "deepseek/deepseek-chat:free",
      "temperature": 0.3,
      "max_tokens": 4096
    },
    {
      "name": "fallback_2",
      "model": "mistralai/mistral-7b-instruct:free",
      "temperature": 0.4,
      "max_tokens": 4096
    },
    {
      "name": "fallback_3",
      "model": "openrouter/auto",
      "temperature": 0.5,
      "max_tokens": 4096
    },
    {
      "name": "last_resort",
      "model": "openrouter/free",
      "temperature": 0.6,
      "max_tokens": 4096
    }
  ],

  "routing": {
    "strategy": "fallback",
    "retry_on_failure": true,
    "max_retries": 5,
    "retry_delay_ms": 2000,
    "timeout_ms": 60000
  },

  "headers": {
    "HTTP-Referer": "http://localhost",
    "X-Title": "zenith-dev-cli"
  },

  "performance": {
    "stream": true,
    "parallel_requests": 1,
    "cache_responses": true,
    "cache_ttl_seconds": 300
  },

  "rate_limit_handling": {
    "on_429": "switch_model",
    "cooldown_ms": 5000,
    "backoff_multiplier": 2
  },

  "logging": {
    "enabled": true,
    "level": "info",
    "log_requests": false,
    "log_responses": false
  }
}
